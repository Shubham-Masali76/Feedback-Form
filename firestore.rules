rules_version = '2';

// Paste this entire file into: Firebase Console → Firestore Database → Rules → Publish
//
// This app mixes:
// - Staff / Admin / HOD: Firebase Auth (request.auth != null)
// - Students: NO Firebase Auth — they query Students / Allocations / Settings and submit Feedbacks
//
// Tighten rules for production (e.g. limit Students reads, rate-limit Feedbacks creates).

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/Users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin';
    }

    function isStaff() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/Users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role in ['staff', 'hod', 'admin'];
    }

    match /Departments/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /Schemes/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /Users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /Students/{docId} {
      // Allow any authenticated user (including students) to get their document
      allow get: if request.auth != null;
      // Allow students to query ONLY their own document by email
      allow list: if isStaff() || (request.auth != null && request.auth.token.email == resource.data.email);
      allow write: if isStaff();
    }

    match /Subjects/{docId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    match /Allocations/{docId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    match /Feedbacks/{docId} {
      allow get: if isStaff();
      allow list: if isStaff() || (request.auth != null && request.auth.token.email == resource.data.studentEmail);
      allow create: if request.auth != null 
        && !exists(/databases/$(database)/documents/Feedbacks/$(docId))
        && docId == request.resource.data.studentRollNo + "_" + request.resource.data.allocationId;
      allow update, delete: if isStaff();
    }

    match /CourseExitForms/{docId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    match /CourseExitResponses/{docId} {
      allow get: if isStaff();
      allow list: if isStaff() || (request.auth != null && request.auth.token.email == resource.data.studentEmail);
      allow create: if request.auth != null;
      allow update, delete: if isStaff();
    }

    match /InstitutionFeedbackResponses/{docId} {
      allow get: if isStaff();
      allow list: if isStaff() || (request.auth != null && request.auth.token.email == resource.data.email);
      allow create: if request.auth != null;
      allow update, delete: if isStaff();
    }

    match /Settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isStaff(); // Some settings might be controlled by HOD
    }
  }
}
